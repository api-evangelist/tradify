{
  "info": {
    "name": "Tradify API (Modeled - Not an Official Public API)",
    "description": "MODELED collection. As of 2026-07-12 Tradify publishes NO open, self-serve, documented public developer API, portal, API keys, or webhooks. There is no public base URL, so the baseUrl variable is intentionally empty. Requests below model the resource surface (jobs, customers, quotes, invoices, timesheets) inferred from Tradify's product and from unofficial third-party proxy descriptions; they are NOT confirmed against official Tradify docs and must not be treated as a supported contract. Tradify's supported programmatic surface is its accounting/payment partner integrations (Xero, MYOB, QuickBooks Online, Sage, Stripe). The live host api.tradifyhq.com is an undocumented, session-authenticated app backend, not a public API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "Authorization", "type": "string" },
      { "key": "value", "value": "{{sessionToken}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "", "type": "string", "description": "MODELED / undocumented. No public Tradify API base URL exists. Left empty on purpose." },
    { "key": "sessionToken", "value": "", "type": "string", "description": "MODELED. No public API key; Tradify's app backend uses a session token from username/password + MFA sign-in." }
  ],
